{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deck",
  "version": "0.7.1",
  "identifier": "com.zhangxingeng.ccstudio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Deck — Claude Code Control Center",
        "width": 1100,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "opener": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "endpoints": [
        "https://github.com/zhangxingeng/deck/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY1QzM1NURFMTY5MDBDOUMKUldTY0RKQVczbFhEWlIvQ0F4d08yZXdsOFhlL1U0M2dvYXlSbWpvY1pPbmVWWkhVV0JlRm5FUVoK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "Utility",
    "shortDescription": "The friendly home for Claude Code — browse, configure, and run it without living in the terminal.",
    "longDescription": "Deck is an independent, offline desktop control center for Claude Code. It auto-discovers your sessions and renders them as clean, readable conversations; gives you one place to see and edit Claude Code settings across user/project/local files with conflicts called out; and launches Claude Code in your own terminal of choice. Your data never leaves your machine. Not affiliated with or endorsed by Anthropic.",
    "publisher": "zhangxingeng",
    "copyright": "Copyright (c) 2026 zhangxingeng. MIT licensed.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
