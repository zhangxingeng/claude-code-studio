{
  "name": "claude-code-studio",
  "version": "0.13.2",
  "description": "CC Deck — an offline desktop control center for Claude Code: browse history, edit settings, and launch it your way.",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:smoke": "tsx tests/smoke.mjs && tsx tests/edit_smoke.mjs && tsx tests/edit_roundtrip_smoke.mjs && tsx tests/title_smoke.mjs && tsx tests/group_smoke.mjs && tsx tests/resume_provider_smoke.mjs && tsx tests/prompts_smoke.mjs && tsx tests/browse_load_smoke.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "dompurify": "^3.4.11",
    "lossless-json": "4.3.0",
    "marked": "^18.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tauri-apps/cli": "^2.11.4",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.4"
  }
}
